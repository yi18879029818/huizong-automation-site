{
  "name": "huizong-next-migration",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "predev": "node ./scripts/sync-legacy-public.mjs",
    "dev": "next dev",
    "prebuild": "node ./scripts/sync-legacy-public.mjs && node ./scripts/minify-legacy-assets.mjs",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^14.2.35",
    "cheerio": "^1.1.2",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@opennextjs/cloudflare": "^1.12.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "wrangler": "^4.38.0"
  }
}
